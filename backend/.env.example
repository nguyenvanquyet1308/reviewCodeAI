APP_ENV=development
APP_NAME="AI GitHub Code Review Platform"

# Database Configuration
# Use postgresql://postgres:postgres@postgres:5432/ai_review inside docker-compose
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_review

# Redis Configuration
# Use redis://redis:6379/0 inside docker-compose
REDIS_URL=redis://localhost:6379/0

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# GitHub Configuration
# Personal Access Token (PAT) with read/write access to PR comments
GITHUB_TOKEN=your_github_token_here
# Secret configured in GitHub repository Webhook settings
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret_here

# Business Logic Configuration
REVIEW_DRAFT_PR=false
MAX_DIFF_CHARS=50000
