# Environment Mode
APP_ENV=production
APP_NAME="AI GitHub Code Review Platform"

# Database Configuration (Used by PostgreSQL container and FastAPI/Celery)
POSTGRES_USER=postgres_admin
POSTGRES_PASSWORD=your_super_secure_postgres_password_here
POSTGRES_DB=ai_review

# Redis Configuration (Keep default when deploying via docker-compose)
REDIS_URL=redis://redis:6379/0

# OpenAI API Configuration
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# GitHub Configuration
# 1. Personal Access Token (PAT) with read/write access to PR comments
GITHUB_TOKEN=github_pat_your_github_token_here
# 2. Secret key configured in your GitHub repository Webhook settings
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret_here

# Code Review Constraints
REVIEW_DRAFT_PR=false
MAX_DIFF_CHARS=50000
